@article{ivanusch2026socialmedia,
  title={Social media savvy? The use and effectiveness of political parties' issue strategies
across platforms in the German federal election campaign 2025},
  author={Ivanusch, Christoph and Luebke, Simon and Wurst, Anna-Katharina and Ha{\ss}ler, J{\"o}rg},
  journal={Minor Revision},
  volume={},
  pages={},
  year={2026},
  publisher={},
  selected={false},
  doi={},
  pdf={},
  bibtex_show={true},
  abstract={How does the ever-growing relevance of social media shape political campaigning? A vibrant public and academic debate addresses the role of social media in elections and democratic processes. Yet, despite a surge in research, we still know little about the extent to which political parties adjust established issue strategies to the priorities of different social media platforms’ audiences and how effective these are in generating user engagement. Drawing on theories of issue competition – issue ownership, riding-the-wave, and issue yield – we analyze parties’ social media communication during the 2025 German federal election campaign on Facebook, Instagram, and TikTok. Combining manual quantitative content analysis of party and candidate posts with large-scale survey data from the German Longitudinal Election Study (GLES), we assess both strategic use and effectiveness of issue strategies. Our results show that parties strategically prioritize owned issues and those salient on the general public agenda, often combining both dimensions in issue yield strategies. However, these strategies only partly align with what the specific platform audiences value and reward. User engagement is highest for posts that match platform-specific issue preferences, especially when the issues are salient both to a party’s supporters on that platform and to its wider user base. The findings offer new insights into the dynamics of contemporary digital campaigning and cross-platform party competition.},
  }

@article{koch2026offtopic,
  title={Going Off-Topic: How Parties Navigate Unfavorable Issue Agendas},
  author={Koch, Elias and Ivanusch, Christoph},
  journal={Work-in-Progress},
  volume={},
  pages={},
  year={2026},
  publisher={},
  selected={false},
  doi={},
  pdf={},
  bibtex_show={true},
  abstract={How do political parties navigate unfavorable issue agendas? Central arenas of party competition are structured around a substantive scope, and parties are frequently confronted with agenda issues offering them only limited competitive advantage. We argue that parties strategically \textit{go off-topic} by diverting from unattractive agenda issues to pivot towards more attractive matters. We test this argument, tracing shifts in partisan issue attention in the German \textit{Bundestag} (2009–2021) and the Austrian \textit{Nationalrat} (1996–2019), combining legislative bills, speeches, and party manifestos classified with fine-tuned transformer models. Following GLM and Difference-in-Differences approaches, we show that parties are more likely to go off-topic when the agenda is dominated by issues they neither own nor prioritize programmatically. Consistent with conventional issue competition theory, they then pivot towards more advantageous issues. Hence, parties compete not only by emphasizing preferred issues, but also by systematically diverting attention away from unfavorable issue agendas in day-to-day politics.},
  }
